{
  "name": "gradiusweb3",
  "version": "1.0.0",
  "author": "Susumu Tomita <oyster880@gmail.com>",
  "license": "MIT",
  "workspaces": ["packages/*"],
  "scripts": {
    "dev": "bun run --filter @gradiusweb3/frontend dev",
    "build": "bun run --filter @gradiusweb3/shared --filter @gradiusweb3/frontend build",
    "test": "bun run --filter @gradiusweb3/shared --filter @gradiusweb3/frontend test",
    "test:coverage": "bun run --filter @gradiusweb3/shared --filter @gradiusweb3/frontend test:coverage",
    "typecheck": "bun run --filter @gradiusweb3/shared --filter @gradiusweb3/frontend typecheck",
    "clean": "bun rimraf node_modules 'packages/*/node_modules' 'packages/*/dist' 'packages/*/coverage'",
    "lint": "bun biome check packages scripts",
    "lint:fix": "bun biome check --write packages scripts",
    "lint:text": "bun textlint ./README.md",
    "lint-staged": "lint-staged",
    "format": "bun biome format --write packages scripts",
    "format:check": "bun biome format packages scripts",
    "prepare": "husky"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@types/node": "^24.9.1",
    "bun-types": "^1.3.11",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.2",
    "rimraf": "^6.1.3",
    "concurrently": "^9.2.1",
    "textlint": "15.4.1",
    "typescript": "^5.9.3",
    "@textlint-ja/textlint-rule-preset-ai-writing": "^1.6.1",
    "textlint-rule-ja-no-abusage": "^3.0.0",
    "textlint-rule-ja-no-inappropriate-words": "^2.0.0",
    "textlint-rule-no-double-negative-ja": "^2.0.1",
    "textlint-rule-no-dropping-the-ra": "^3.0.0",
    "textlint-rule-prefer-tari-tari": "^1.0.3",
    "textlint-rule-preset-ja-spacing": "^2.2.0",
    "textlint-rule-preset-ja-technical-writing": "^12.0.2",
    "textlint-rule-spellcheck-tech-word": "^5.0.0"
  }
}
